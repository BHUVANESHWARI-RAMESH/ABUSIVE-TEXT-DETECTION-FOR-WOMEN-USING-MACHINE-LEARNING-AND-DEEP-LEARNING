import pandas as pd
import numpy as np
import joblib

from google.colab import files

from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.feature_selection import SelectKBest, chi2

from sklearn.model_selection import GridSearchCV

from sklearn.ensemble import RandomForestClassifier
from sklearn.naive_bayes import MultinomialNB
from sklearn.linear_model import LogisticRegression
from sklearn.svm import SVC

from sklearn.metrics import (
    accuracy_score,
    precision_score,
    recall_score,
    f1_score,
    confusion_matrix,
    classification_report
)




print("UPLOAD TRAINING DATASET")

uploaded_train = files.upload()

train_file = list(uploaded_train.keys())[0]





train_data = pd.read_csv(
    train_file,
    header=None,
    names=["text", "class"],
    encoding="utf-8"
)





train_data = train_data.dropna()






train_data["class"] = (
    train_data["class"]
    .astype(str)
    .str.lower()
    .str.strip()
)





label_map = {
    "abusive": 1,
    "non-abusive": 0,
    "non abusive": 0,
    "nonabusive": 0
}

train_data["label"] = train_data["class"].map(label_map)





train_data = train_data.dropna(subset=["label"])




X_train = train_data["text"].astype(str)

y_train = train_data["label"].astype(int)

print("\nTRAINING SAMPLES :", len(X_train))





vectorizer = TfidfVectorizer(
    max_features=10000,
    ngram_range=(1,2),
    sublinear_tf=True,
    stop_words='english'
)

X_train_tfidf = vectorizer.fit_transform(X_train)

print("\nTF-IDF SHAPE :", X_train_tfidf.shape)




selector = SelectKBest(chi2, k=5000)

X_train_selected = selector.fit_transform(
    X_train_tfidf,
    y_train
)

print("\nAFTER FEATURE SELECTION :", X_train_selected.shape)




print("\nTRAINING RANDOM FOREST...")

rf_model = RandomForestClassifier(random_state=42)

rf_params = {
    'n_estimators': [100, 200],
    'max_depth': [None, 10, 20],
    'criterion': ['gini', 'entropy']
}

rf_grid = GridSearchCV(
    rf_model,
    rf_params,
    cv=5,
    scoring='accuracy',
    n_jobs=-1
)

rf_grid.fit(X_train_selected, y_train)

best_rf = rf_grid.best_estimator_

print("\nBEST RANDOM FOREST PARAMETERS :")
print(rf_grid.best_params_)




print("\nTRAINING NAIVE BAYES...")

nb_model = MultinomialNB()

nb_params = {
    'alpha': [0.1, 0.5, 1.0]
}

nb_grid = GridSearchCV(
    nb_model,
    nb_params,
    cv=5,
    scoring='accuracy',
    n_jobs=-1
)

nb_grid.fit(X_train_selected, y_train)

best_nb = nb_grid.best_estimator_

print("\nBEST NAIVE BAYES PARAMETERS :")
print(nb_grid.best_params_)




print("\nTRAINING LOGISTIC REGRESSION...")

lr_model = LogisticRegression()

lr_params = {
    'C': [0.1, 1, 10],
    'solver': ['liblinear', 'lbfgs'],
    'max_iter': [1000, 2000]
}

lr_grid = GridSearchCV(
    lr_model,
    lr_params,
    cv=5,
    scoring='accuracy',
    n_jobs=-1
)

lr_grid.fit(X_train_selected, y_train)

best_lr = lr_grid.best_estimator_

print("\nBEST LOGISTIC REGRESSION PARAMETERS :")
print(lr_grid.best_params_)





print("\nTRAINING SVM...")

svm_model = SVC()

svm_params = {
    'C': [0.1, 1, 10],
    'kernel': ['linear', 'rbf'],
    'gamma': ['scale', 'auto']
}

svm_grid = GridSearchCV(
    svm_model,
    svm_params,
    cv=5,
    scoring='accuracy',
    n_jobs=-1
)

svm_grid.fit(X_train_selected, y_train)

best_svm = svm_grid.best_estimator_

print("\nBEST SVM PARAMETERS :")
print(svm_grid.best_params_)





print("\nUPLOAD TEST DATASET (UNLABELED)")

uploaded_test = files.upload()

test_file = list(uploaded_test.keys())[0]

test_data = pd.read_csv(
    test_file,
    encoding="utf-8",
    engine="python"
)





X_test = test_data.iloc[:, 0].astype(str)





X_test = X_test[X_test != "Text"]

X_test = X_test[X_test.str.strip() != ""]

X_test = X_test.reset_index(drop=True)

print("\nTEST SAMPLES :", len(X_test))






X_test_tfidf = vectorizer.transform(X_test)

X_test_selected = selector.transform(X_test_tfidf)





rf_pred = best_rf.predict(X_test_selected)

nb_pred = best_nb.predict(X_test_selected)

lr_pred = best_lr.predict(X_test_selected)

svm_pred = best_svm.predict(X_test_selected)

print("\nPREDICTIONS COMPLETED SUCCESSFULLY!")




print("\nUPLOAD ORIGINAL LABEL DATASET")

uploaded_original = files.upload()

original_file = list(uploaded_original.keys())[0]





encodings = [
    "utf-8",
    "utf-8-sig",
    "latin1",
    "cp1252",
    "ISO-8859-1",
    "utf-16"
]

original_data = None

for enc in encodings:

    try:

        original_data = pd.read_csv(
            original_file,
            encoding=enc,
            engine="python",
            on_bad_lines="skip"
        )

        print(f"\nLOADED USING ENCODING : {enc}")

        break

    except Exception as e:

        print(e)




y_true = (
    original_data.iloc[:, 1]
    .fillna(0)
    .astype(int)
)

y_true = y_true.reset_index(drop=True)





min_len = min(len(y_true), len(rf_pred))

y_true = y_true[:min_len]

rf_pred = rf_pred[:min_len]

nb_pred = nb_pred[:min_len]

lr_pred = lr_pred[:min_len]

svm_pred = svm_pred[:min_len]

X_test = X_test[:min_len]

print("\nFINAL SAMPLES USED :", min_len)





def evaluate_model(model_name, y_true, y_pred):

    print("\n===================================")
    print(model_name)
    print("===================================\n")

    accuracy = accuracy_score(y_true, y_pred)

    precision = precision_score(y_true, y_pred)

    recall = recall_score(y_true, y_pred)

    f1 = f1_score(y_true, y_pred)

    print(f"Accuracy  : {accuracy:.4f}")
    print(f"Precision : {precision:.4f}")
    print(f"Recall    : {recall:.4f}")
    print(f"F1 Score  : {f1:.4f}")

    print("\nCONFUSION MATRIX :\n")

    print(confusion_matrix(y_true, y_pred))

    print("\nCLASSIFICATION REPORT :\n")

    print(classification_report(y_true, y_pred))





evaluate_model(
    "RANDOM FOREST PERFORMANCE",
    y_true,
    rf_pred
)

evaluate_model(
    "NAIVE BAYES PERFORMANCE",
    y_true,
    nb_pred
)

evaluate_model(
    "LOGISTIC REGRESSION PERFORMANCE",
    y_true,
    lr_pred
)

evaluate_model(
    "SVM PERFORMANCE",
    y_true,
    svm_pred
)





output_df = pd.DataFrame()

output_df["Text"] = X_test.values

output_df["Original_Label"] = y_true.values

output_df["RF_Prediction"] = rf_pred

output_df["NB_Prediction"] = nb_pred

output_df["LR_Prediction"] = lr_pred

output_df["SVM_Prediction"] = svm_pred





label_reverse = {
    0: "non-abusive",
    1: "abusive"
}

output_df["Original_Label"] = (
    output_df["Original_Label"]
    .map(label_reverse)
)

output_df["RF_Prediction"] = (
    output_df["RF_Prediction"]
    .map(label_reverse)
)

output_df["NB_Prediction"] = (
    output_df["NB_Prediction"]
    .map(label_reverse)
)

output_df["LR_Prediction"] = (
    output_df["LR_Prediction"]
    .map(label_reverse)
)

output_df["SVM_Prediction"] = (
    output_df["SVM_Prediction"]
    .map(label_reverse)
)






output_file = "Final_Result.csv"

output_df.to_csv(
    output_file,
    index=False,
    encoding="utf-8-sig"
)

print("\nFINAL RESULT FILE SAVED SUCCESSFULLY!")

files.download(output_file)





joblib.dump(best_rf, "RandomForest_Model.pkl")

joblib.dump(best_nb, "NaiveBayes_Model.pkl")

joblib.dump(best_lr, "LogisticRegression_Model.pkl")

joblib.dump(best_svm, "SVM_Model.pkl")

joblib.dump(vectorizer, "TFIDF_Vectorizer.pkl")

joblib.dump(selector, "Feature_Selector.pkl")

print("\nALL MODELS SAVED SUCCESSFULLY!")




